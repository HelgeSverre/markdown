# Composer
/vendor/
composer.phar

# IDE / editors
/.idea/
/.vscode/
*.swp
.DS_Store

# Compiled native FFI artifacts (build with native/build.sh)
native/*.dylib
native/*.so
native/*.dll
native/*.o
native/*.a
# Profiling build by-product (native/build.sh profile): the macOS debug bundle.
# The libmd4cshim.prof.* lib itself is already covered by the globs above.
native/*.dSYM/
# Generated FFI scope header (build.sh writes it with a machine-specific path)
native/md4cshim.h

# Prebuilt platform libraries under lib/ ARE committed and shipped, but never
# their build by-products:
lib/**/*.pdb
lib/**/*.lib
lib/**/*.exp

# Large synthetic corpus tiers (regenerate with `composer corpus`).
# The small tiers (2kb/16kb/128kb) stay committed; these two would bloat clones.
/corpus/synthetic/doc-1mb.md
/corpus/synthetic/doc-8mb.md

# Example output
/examples/output/

# Tool caches
.phpunit.result.cache
.phpunit.cache/
.phpbench/
# Mago's binary lives in vendor/; only a baseline dir would land here if ever generated.
/.mago/
/_storage/

# PHPBench intermediate dump (RESULTS.md + results.json are the artifacts)
/results/raw.xml

# Raw native-sampler dump (PROFILE.md is the artifact; this is its raw input)
/results/profile.sample.txt

profile.json.gz
# Throwaway real-world doc corpora (cloned for ad-hoc benchmarking, not committed)
/corpus/realworld/

# WIP integration experiments (cloned real apps, not committed)
/wip/
