# Composer
/vendor/
composer.phar

# IDE / editors
/.idea/
/.vscode/
*.swp
.DS_Store

# Compiled native FFI artifacts (build with native/build.sh)
native/*.dylib
native/*.so
native/*.dll
native/*.o
native/*.a
# Generated FFI scope header (build.sh writes it with a machine-specific path)
native/md4cshim.h

# Prebuilt platform libraries under lib/ ARE committed and shipped, but never
# their build by-products:
lib/**/*.pdb
lib/**/*.lib
lib/**/*.exp

# Example output
/examples/output/

# Tool caches
.phpunit.result.cache
.phpunit.cache/
.php-cs-fixer.cache
.phpbench/
/_storage/
