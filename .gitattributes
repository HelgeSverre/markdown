# Keep the Composer dist lean — dev-only material isn't shipped to consumers.
# (Affects `composer require` dist archives; full git clones still get everything.)
/.github         export-ignore
/bench           export-ignore
/tests           export-ignore
/corpus          export-ignore
/results         export-ignore
/examples        export-ignore
/docs            export-ignore
/phpunit.xml     export-ignore
/phpbench.json   export-ignore
/mago.toml       export-ignore
/.gitattributes  export-ignore
/.gitignore      export-ignore
/composer.lock   export-ignore
/CLAUDE.md       export-ignore
/AGENTS.md       export-ignore

# Prebuilt native libraries are binary; never munge line endings or diff them.
lib/** binary
*.dylib binary
*.so    binary
*.dll   binary
